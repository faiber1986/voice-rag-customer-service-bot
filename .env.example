# Voice-RAG Bot configuration
# Default setup runs fully local/free (Ollama + Chroma + faster-whisper + piper).
# Fill these in only if you want to swap in hosted providers later (see README "Future Work").

# --- Local stack (defaults, no keys needed) ---
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text
WHISPER_MODEL_SIZE=base.en
PIPER_VOICE=en_US-lessac-medium
CHROMA_PERSIST_DIR=data/chroma

# --- Optional hosted providers (not used by default) ---
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=
# DEEPGRAM_API_KEY=
# PINECONE_API_KEY=
